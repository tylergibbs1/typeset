{
  "name": "@typeset/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "typeset": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile typeset",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typeset/engine": "workspace:*",
    "@typeset/sdk": "workspace:*",
    "commander": "^13"
  },
  "devDependencies": {
    "bun-types": "^1.3",
    "typescript": "^5.8"
  }
}
